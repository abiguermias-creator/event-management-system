<!DOCTYPE html>
<html>
<head>
    <title>Event Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>🎉 Event Dashboard</h2>

        <a href="/events/new" class="btn btn-success">
            + Create Event
        </a>
    </div>

    <!-- SEARCH -->
    <form method="GET" action="/events" class="mb-4">
        <div class="input-group">
            <input 
                type="text"
                name="search"
                class="form-control"
                placeholder="Search events..."
                value="<%= search || '' %>"
            >
            <button class="btn btn-primary">Search</button>
        </div>
    </form>

    <div class="row">

        <% events.forEach(event => { %>

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h5><%= event.name %></h5>

                    <p>📅 <%= event.date %></p>
                    <p>📍 <%= event.location %></p>

                    <p class="text-success">
                        🎟 Tickets: <%= event.tickets %>
                    </p>

                    <a href="/events/edit/<%= event.id %>" class="btn btn-primary btn-sm">
                        Edit
                    </a>

                    <form action="/events/delete/<%= event.id %>" method="POST" style="display:inline;">
                        <button class="btn btn-danger btn-sm">
                            Delete
                        </button>
                    </form>

                    <form action="/events/book/<%= event.id %>" method="POST" style="display:inline;">
                        <button class="btn btn-warning btn-sm">
                            Book Ticket
                        </button>
                    </form>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

</div>

</body>
</html>